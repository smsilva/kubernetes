#!/bin/bash

# Obtém o ARN do usuário/role IAM atual para conceder acesso ao cluster
caller_arn=$(aws sts get-caller-identity --query Arn --output text)

cat <<EOF | kubectl apply -f -
---
apiVersion: eks.aws.upbound.io/v1beta1
kind: AccessEntry
metadata:
  name: eks-access-entry
spec:
  forProvider:
    region: us-east-1
    clusterNameRef:
      name: eks-cluster
    principalArn: ${caller_arn}
    tags:
      Name: eks-access-entry
EOF

kubectl wait accessentry.eks.aws.upbound.io/eks-access-entry \
  --for=condition=Ready \
  --timeout=120s

cat <<EOF | kubectl apply -f -
---
apiVersion: eks.aws.upbound.io/v1beta1
kind: AccessPolicyAssociation
metadata:
  name: eks-access-admin
spec:
  forProvider:
    region: us-east-1
    clusterNameRef:
      name: eks-cluster
    principalArn: ${caller_arn}
    policyArn: arn:aws:eks::aws:cluster-access-policy/AmazonEKSClusterAdminPolicy
    accessScope:
      type: cluster
EOF

kubectl wait accesspolicyassociation.eks.aws.upbound.io/eks-access-admin \
  --for=condition=Ready \
  --timeout=120s

kubectl get accessentries.eks.aws.upbound.io
kubectl get accesspolicyassociations.eks.aws.upbound.io

# Atualiza o kubeconfig local
cluster_region=$(kubectl get cluster.eks.aws.upbound.io/eks-cluster \
  -o jsonpath='{.spec.forProvider.region}')

aws eks update-kubeconfig \
  --region ${cluster_region} \
  --name eks-cluster
