#!/bin/bash
# bootstrap: valida pré-requisitos antes de criar ou destruir recursos do lab EKS
# Uso: ./bootstrap [--create | --destroy]

set -euo pipefail
. "$(dirname "$0")/env.conf"

secrets_file="$(dirname "$0")/env.secrets"
if [[ -f "${secrets_file}" ]]; then
  . "${secrets_file}"
fi

mode="${1:---create}"
errors=0

red="\033[0;31m"
green="\033[0;32m"
yellow="\033[1;33m"
reset="\033[0m"

ok()   { echo -e "${green}[OK]${reset}   $*"; }
fail() { echo -e "${red}[FAIL]${reset} $*"; errors=$((errors + 1)); }
warn() { echo -e "${yellow}[WARN]${reset} $*"; }
section() { echo -e "\n=== $* ==="; }

# =============================================================================
# CLIs obrigatórias
# =============================================================================
section "Ferramentas CLI"

declare -A tool_version_cmd=(
  [aws]="aws --version"
  [eksctl]="eksctl version"
  [kubectl]="kubectl version --client --short"
  [helm]="helm version --short"
  [istioctl]="istioctl version --remote=false"
  [docker]="docker --version"
  [az]="az version --output tsv --query '\"azure-cli\"'"
)

for tool in aws eksctl kubectl helm istioctl docker az; do
  if command -v "${tool}" &>/dev/null; then
    version=$(${tool_version_cmd[$tool]} 2>/dev/null | head -1 || echo 'versão não detectada')
    ok "${tool}: ${version}"
  else
    fail "${tool} não encontrado no PATH"
  fi
done

# =============================================================================
# AWS — credenciais e região
# =============================================================================
section "AWS"

caller_identity=$(aws sts get-caller-identity --region "${aws_region}" --output json 2>&1) || {
  fail "AWS: credenciais inválidas ou expiradas — rode 'aws sso login'"
  caller_identity=""
}

if [[ -n "${caller_identity}" ]]; then
  account_id=$(echo "${caller_identity}" | python3 -c "import sys,json; print(json.load(sys.stdin)['Account'])")
  caller_arn=$(echo "${caller_identity}" | python3 -c "import sys,json; print(json.load(sys.stdin)['Arn'])")

  if [[ "${account_id}" == "221047292361" ]]; then
    ok "AWS account: ${account_id}"
  else
    fail "AWS account inesperada: ${account_id} (esperado: 221047292361)"
  fi

  ok "AWS caller: ${caller_arn}"
fi

# =============================================================================
# Azure CLI — subscription wasp-sandbox
# =============================================================================
section "Azure"

az_state=$(az account show --subscription "${az_subscription}" --query 'state' --output tsv 2>&1) || {
  fail "Azure: não autenticado ou subscription '${az_subscription}' inacessível — rode 'az login'"
  az_state=""
}

if [[ "${az_state}" == "Enabled" ]]; then
  ok "Azure subscription '${az_subscription}': Enabled"
else
  [[ -n "${az_state}" ]] && fail "Azure subscription '${az_subscription}': ${az_state}"
fi

# =============================================================================
# Docker daemon
# =============================================================================
section "Docker"

if docker info &>/dev/null; then
  docker_version=$(docker info --format '{{.ServerVersion}}' 2>/dev/null)
  ok "Docker daemon rodando (v${docker_version})"
else
  fail "Docker daemon não está rodando"
fi

# =============================================================================
# Secrets obrigatórias (apenas no modo create)
# =============================================================================
if [[ "${mode}" == "--create" ]]; then
  section "Secrets (modo create)"

  for var in GOOGLE_CLIENT_ID GOOGLE_CLIENT_SECRET STATE_JWT_SECRET; do
    val="${!var:-}"
    if [[ -n "${val}" ]]; then
      ok "${var} definida"
    else
      fail "${var} não definida ou vazia — preencher em env.secrets"
    fi
  done
fi

# =============================================================================
# Resultado final
# =============================================================================
echo ""
if [[ "${errors}" -eq 0 ]]; then
  echo -e "${green}Todos os pré-requisitos atendidos. Pode prosseguir.${reset}"
  exit 0
else
  echo -e "${red}${errors} problema(s) encontrado(s). Corrija antes de continuar.${reset}"
  exit 1
fi
