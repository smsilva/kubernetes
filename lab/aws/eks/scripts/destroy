#!/bin/bash
# Destrói todos os recursos do lab na ordem inversa da criação
#
# Ordem de deleção:
#  1. Sample app (VirtualService, Gateway Istio, Service, Deployment, Namespace)
#  2. DNS Azure: CNAME wildcard *.domain e A records do apex
#  3. Global Accelerator: endpoint group, listener, accelerator
#  4. WAF: desassocia WebACL do ALB e deleta a WebACL
#  5. Ingress: alb-ingress (Ingress), alb (IngressClass)
#  6. Istio: istio-ingressgateway, istiod, istio-base, namespaces
#  7. ALB Controller: Helm, IAM service account, IAM policy
#  8. Cluster EKS (eksctl — inclui node group e OIDC provider)
#  9. VPC: route tables, NAT GW, EIP, IGW, subnets, VPC

set -euo pipefail
. "$(dirname "$0")/env.conf"
. "$(dirname "$0")/.vpc-ids"

az_zone="${domain}"

# =============================================================================
# 1. Sample app
# =============================================================================
echo "Removendo sample app..."
kubectl delete namespace sample --ignore-not-found

# =============================================================================
# 2. DNS Azure — CNAME wildcard e A records do apex
# =============================================================================
echo "Removendo registro CNAME *.${domain} do Azure DNS..."
az network dns record-set cname delete \
  --subscription "${az_subscription}" \
  --resource-group "${az_resource_group}" \
  --zone-name "${az_zone}" \
  --name "*" \
  --yes 2>/dev/null || true

echo "Removendo A records do apex ${domain} do Azure DNS..."
az network dns record-set a delete \
  --subscription "${az_subscription}" \
  --resource-group "${az_resource_group}" \
  --zone-name "${az_zone}" \
  --name "@" \
  --yes 2>/dev/null || true

# =============================================================================
# 3. Global Accelerator
# =============================================================================
if [[ -n "${global_accelerator_arn:-}" && "${global_accelerator_arn}" != '""' ]]; then
  echo "Removendo Global Accelerator..."

  listener_arn=$(
    aws globalaccelerator list-listeners \
      --region us-east-1 \
      --accelerator-arn "${global_accelerator_arn}" \
      --query 'Listeners[0].ListenerArn' \
      --output text 2>/dev/null || echo ""
  )

  if [[ -n "${listener_arn}" && "${listener_arn}" != "None" ]]; then
    endpoint_group_arn=$(
      aws globalaccelerator list-endpoint-groups \
        --region us-east-1 \
        --listener-arn "${listener_arn}" \
        --query 'EndpointGroups[0].EndpointGroupArn' \
        --output text 2>/dev/null || echo ""
    )

    if [[ -n "${endpoint_group_arn}" && "${endpoint_group_arn}" != "None" ]]; then
      aws globalaccelerator delete-endpoint-group \
        --region us-east-1 \
        --endpoint-group-arn "${endpoint_group_arn}"
    fi

    aws globalaccelerator delete-listener \
      --region us-east-1 \
      --listener-arn "${listener_arn}"
  fi

  aws globalaccelerator update-accelerator \
    --region us-east-1 \
    --accelerator-arn "${global_accelerator_arn}" \
    --no-enabled

  aws globalaccelerator delete-accelerator \
    --region us-east-1 \
    --accelerator-arn "${global_accelerator_arn}"

  echo "Global Accelerator removido."
fi

# =============================================================================
# 4. WAF
# =============================================================================
echo "Removendo WAF..."
alb_arn=$(
  aws resourcegroupstaggingapi get-resources \
    --region "${aws_region?}" \
    --resource-type-filters elasticloadbalancing:loadbalancer \
    --tag-filters "Key=project,Values=${tag_project}" "Key=env,Values=${tag_env}" \
    --query 'ResourceTagMappingList[0].ResourceARN' \
    --output text
)

if [[ -n "${alb_arn}" && "${alb_arn}" != "None" ]]; then
  aws wafv2 disassociate-web-acl \
    --region "${aws_region?}" \
    --resource-arn "${alb_arn}"
fi

web_acl_id=$(
  aws wafv2 list-web-acls \
    --region "${aws_region?}" \
    --scope REGIONAL \
    --query "WebACLs[?Name=='${cluster_name}-web-acl'].Id" \
    --output text
)

if [[ -n "${web_acl_id}" && "${web_acl_id}" != "None" ]]; then
  lock_token=$(
    aws wafv2 get-web-acl \
      --region "${aws_region?}" \
      --scope REGIONAL \
      --name "${cluster_name}-web-acl" \
      --id "${web_acl_id}" \
      --query 'LockToken' --output text
  )

  aws wafv2 delete-web-acl \
    --region "${aws_region?}" \
    --scope REGIONAL \
    --name "${cluster_name}-web-acl" \
    --id "${web_acl_id}" \
    --lock-token "${lock_token}"
fi

# =============================================================================
# 5. Ingress + IngressClass
# =============================================================================
echo "Removendo Ingress e IngressClass..."
kubectl --namespace istio-ingress delete ingress alb-ingress --ignore-not-found
kubectl delete ingressclass alb --ignore-not-found

# =============================================================================
# 6. Istio
# =============================================================================
echo "Removendo Istio..."
helm uninstall istio-ingressgateway --namespace istio-ingress 2>/dev/null || true
helm uninstall istiod --namespace istio-system 2>/dev/null || true
helm uninstall istio-base --namespace istio-system 2>/dev/null || true

# CRDs do Istio são retidos pela resource policy — deletar explicitamente
kubectl get crd -o name | grep '\.istio\.io' | xargs -r kubectl delete

kubectl delete namespace istio-ingress --ignore-not-found
kubectl delete namespace istio-system --ignore-not-found

# =============================================================================
# 7. ALB Controller
# =============================================================================
echo "Removendo ALB Controller..."
helm uninstall aws-load-balancer-controller --namespace kube-system 2>/dev/null || true

eksctl delete iamserviceaccount \
  --cluster "${cluster_name?}" \
  --region "${aws_region?}" \
  --namespace kube-system \
  --name aws-load-balancer-controller

policy_arn=$(
  aws iam list-policies \
    --query "Policies[?PolicyName=='AWSLoadBalancerControllerIAMPolicy'].Arn" \
    --output text
)

if [[ -n "${policy_arn}" && "${policy_arn}" != "None" ]]; then
  aws iam delete-policy --policy-arn "${policy_arn}"
fi

# =============================================================================
# 8. Cluster EKS
# =============================================================================
echo "Removendo cluster EKS (aguarde vários minutos)..."
eksctl delete cluster \
  --name "${cluster_name?}" \
  --region "${aws_region?}" \
  --wait

# =============================================================================
# 9. VPC
# =============================================================================
echo "Removendo recursos de rede..."

# Route table associations (desassociar antes de deletar as route tables)
for rt in "${rt_public}" "${rt_private}"; do
  assoc_ids=$(
    aws ec2 describe-route-tables \
      --route-table-ids "${rt}" \
      --region "${aws_region?}" \
      --query 'RouteTables[0].Associations[?!Main].RouteTableAssociationId' \
      --output text
  )
  for assoc_id in ${assoc_ids}; do
    aws ec2 disassociate-route-table --association-id "${assoc_id}"
  done
done

# Routes customizadas
aws ec2 delete-route \
  --route-table-id "${rt_public?}" \
  --destination-cidr-block 0.0.0.0/0 2>/dev/null || true

aws ec2 delete-route \
  --route-table-id "${rt_private?}" \
  --destination-cidr-block 0.0.0.0/0 2>/dev/null || true

# Route tables
aws ec2 delete-route-table --route-table-id "${rt_public?}" --region "${aws_region?}"
aws ec2 delete-route-table --route-table-id "${rt_private?}" --region "${aws_region?}"

# NAT Gateway (demora alguns minutos)
echo "Removendo NAT Gateway (aguarde ~2 minutos)..."
aws ec2 delete-nat-gateway \
  --nat-gateway-id "${nat_gw_id?}" \
  --region "${aws_region?}"

aws ec2 wait nat-gateway-deleted \
  --nat-gateway-ids "${nat_gw_id?}" \
  --region "${aws_region?}"

# EIP
aws ec2 release-address \
  --allocation-id "${eip_alloc?}" \
  --region "${aws_region?}"

# Internet Gateway
aws ec2 detach-internet-gateway \
  --internet-gateway-id "${igw_id?}" \
  --vpc-id "${vpc_id?}"

aws ec2 delete-internet-gateway \
  --internet-gateway-id "${igw_id?}" \
  --region "${aws_region?}"

# Subnets
for subnet in "${subnet_pub_1a}" "${subnet_pub_1b}" "${subnet_priv_1a}" "${subnet_priv_1b}"; do
  aws ec2 delete-subnet --subnet-id "${subnet}" --region "${aws_region?}"
done

# VPC
aws ec2 delete-vpc --vpc-id "${vpc_id?}" --region "${aws_region?}"

echo ""
echo "Todos os recursos do lab foram removidos."
echo "Atenção: o certificado ACM não foi removido — deletar manualmente se necessário."

# Limpa arquivo de IDs para evitar uso acidental em execuções futuras
rm -f "$(dirname "$0")/.vpc-ids"
