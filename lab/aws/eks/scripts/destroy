#!/bin/bash
# Destrói todos os recursos do lab na ordem inversa da criação
#
# Ordem de deleção:
#  1. Sample app (VirtualService, Gateway Istio, Service, Deployment, Namespace)
#  2. DNS Azure: CNAME wildcard *.domain, A records do apex e CNAME idp (Cognito)
#  3. Cognito: custom domain idp.domain (deleta CloudFront distribution — pode levar minutos)
#  4. Cognito: User Pool wasp-platform (inclui IdPs e App Clients)
#  5. Lambda: wasp-pre-token-generation + IAM role wasp-pre-token-lambda-role
#  6. IAM role wasp-discovery-irsa + DynamoDB tenant-registry
#  7. Global Accelerator: endpoint group, listener, accelerator
#  8. WAF: desassocia WebACL do ALB e deleta a WebACL
#  9. Ingress: alb-ingress (Ingress), alb (IngressClass)
# 10. Istio: istio-ingressgateway, istiod, istio-base, namespaces
# 11. ALB Controller: Helm, IAM service account, IAM policy
# 12. Cluster EKS (eksctl — inclui node group e OIDC provider)
# 13. VPC: route tables, NAT GW, EIP, IGW, subnets, VPC

set -euo pipefail
. "$(dirname "$0")/env.conf"
vpc_ids_file="$(dirname "$0")/.vpc-ids"
if [[ -f "${vpc_ids_file}" ]]; then
  . "${vpc_ids_file}"
fi

az_zone="${domain}"

# =============================================================================
# 1. Tenant apps (customer1, customer2) + sample app
# =============================================================================
echo "Removendo tenant apps (tenant-frontend, httpbin) dos namespaces customer1 e customer2..."
for ns in customer1 customer2; do
  kubectl -n "${ns}" delete deployment tenant-frontend httpbin --ignore-not-found 2>/dev/null || true
  kubectl -n "${ns}" delete service tenant-frontend httpbin --ignore-not-found 2>/dev/null || true
  kubectl -n "${ns}" delete configmap tenant-frontend-config --ignore-not-found 2>/dev/null || true
  kubectl delete namespace "${ns}" --ignore-not-found 2>/dev/null || true
done

echo "Removendo sample app..."
kubectl delete namespace sample --ignore-not-found 2>/dev/null || true

# =============================================================================
# 2. DNS Azure — CNAME wildcard e A records do apex
# =============================================================================
echo "Removendo registro CNAME *.${domain} do Azure DNS..."
az network dns record-set cname delete \
  --subscription "${az_subscription}" \
  --resource-group "${az_resource_group}" \
  --zone-name "${az_zone}" \
  --name "*" \
  --yes 2>/dev/null || true

echo "Removendo A records do apex ${domain} do Azure DNS..."
az network dns record-set a delete \
  --subscription "${az_subscription}" \
  --resource-group "${az_resource_group}" \
  --zone-name "${az_zone}" \
  --name "@" \
  --yes 2>/dev/null || true

echo "Removendo CNAME idp.${domain} do Azure DNS..."
az network dns record-set cname delete \
  --subscription "${az_subscription}" \
  --resource-group "${az_resource_group}" \
  --zone-name "${az_zone}" \
  --name "idp" \
  --yes 2>/dev/null || true

# =============================================================================
# 3. Cognito — custom domain idp.domain
# =============================================================================
cognito_domain="idp.${domain}"

if [[ -n "${cognito_user_pool_id:-}" && "${cognito_user_pool_id}" != '""' ]]; then
  domain_status=$(
    aws cognito-idp describe-user-pool-domain \
      --region "${aws_region?}" \
      --domain "${cognito_domain}" \
      --query 'DomainDescription.Status' \
      --output text 2>/dev/null || echo "NOT_FOUND"
  )

  if [[ "${domain_status}" != "NOT_FOUND" && "${domain_status}" != "None" && -n "${domain_status}" ]]; then
    echo "Removendo Cognito custom domain '${cognito_domain}' (deleta CloudFront distribution — aguarde)..."
    aws cognito-idp delete-user-pool-domain \
      --region "${aws_region?}" \
      --domain "${cognito_domain}" \
      --user-pool-id "${cognito_user_pool_id}"

    for i in $(seq 1 40); do
      domain_status=$(
        aws cognito-idp describe-user-pool-domain \
          --region "${aws_region?}" \
          --domain "${cognito_domain}" \
          --query 'DomainDescription.Status' \
          --output text 2>/dev/null || echo "NOT_FOUND"
      )
      echo "  Status: ${domain_status} (${i}/40)"
      if [[ "${domain_status}" == "NOT_FOUND" || "${domain_status}" == "None" || -z "${domain_status}" ]]; then
        break
      fi
      sleep 15
    done

    echo "Cognito custom domain removido."
  else
    echo "Cognito custom domain '${cognito_domain}' não encontrado — ignorando."
  fi
fi

# =============================================================================
# 4. Cognito — User Pool wasp-platform
# =============================================================================
if [[ -n "${cognito_user_pool_id:-}" && "${cognito_user_pool_id}" != '""' ]]; then
  pool_exists=$(
    aws cognito-idp describe-user-pool \
      --region "${aws_region?}" \
      --user-pool-id "${cognito_user_pool_id}" \
      --query 'UserPool.Id' \
      --output text 2>/dev/null || echo "NOT_FOUND"
  )

  if [[ "${pool_exists}" != "NOT_FOUND" && -n "${pool_exists}" ]]; then
    echo "Removendo User Pool '${cognito_user_pool_id}' (inclui IdPs e App Clients)..."
    aws cognito-idp delete-user-pool \
      --region "${aws_region?}" \
      --user-pool-id "${cognito_user_pool_id}"
    echo "User Pool removido."
  else
    echo "User Pool '${cognito_user_pool_id}' não encontrado — ignorando."
  fi
fi

# =============================================================================
# 5. Lambda — wasp-pre-token-generation + IAM role wasp-pre-token-lambda-role
# =============================================================================
lambda_function_name="wasp-pre-token-generation"
lambda_role_name="wasp-pre-token-lambda-role"
aws_account_id=$(aws sts get-caller-identity --query Account --output text)

echo "Removendo Lambda '${lambda_function_name}'..."
aws lambda delete-function \
  --region "${aws_region?}" \
  --function-name "${lambda_function_name}" 2>/dev/null || true

echo "Removendo IAM role '${lambda_role_name}'..."
# Inline policies devem ser removidas antes da role
aws iam delete-role-policy \
  --role-name "${lambda_role_name}" \
  --policy-name "DynamoDBTenantRegistry" 2>/dev/null || true

aws iam detach-role-policy \
  --role-name "${lambda_role_name}" \
  --policy-arn "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole" 2>/dev/null || true

aws iam delete-role \
  --role-name "${lambda_role_name}" 2>/dev/null || true

echo "Lambda e IAM role removidos."

# =============================================================================
# 6. IAM role wasp-discovery-irsa + DynamoDB tenant-registry
# =============================================================================
discovery_irsa_role="wasp-discovery-irsa"
dynamodb_table="tenant-registry"

echo "Removendo IAM role '${discovery_irsa_role}'..."
aws iam delete-role-policy \
  --role-name "${discovery_irsa_role}" \
  --policy-name "DynamoDBTenantRegistryRead" 2>/dev/null || true

aws iam delete-role \
  --role-name "${discovery_irsa_role}" 2>/dev/null || true

echo "Removendo tabela DynamoDB '${dynamodb_table}'..."
aws dynamodb delete-table \
  --region "${aws_region?}" \
  --table-name "${dynamodb_table}" 2>/dev/null || true

echo "IAM role discovery e DynamoDB removidos."

# =============================================================================
# 7. Global Accelerator
# =============================================================================
if [[ -n "${global_accelerator_arn:-}" && "${global_accelerator_arn}" != '""' ]]; then
  echo "Removendo Global Accelerator..."

  # Global Accelerator usa us-west-2 como região de controle (padrão do serviço)
  ga_opts=(--region us-west-2)

  listener_arn=$(
    aws globalaccelerator list-listeners \
      "${ga_opts[@]}" \
      --accelerator-arn "${global_accelerator_arn}" \
      --query 'Listeners[0].ListenerArn' \
      --output text 2>/dev/null || echo ""
  )

  if [[ -n "${listener_arn}" && "${listener_arn}" != "None" ]]; then
    endpoint_group_arn=$(
      aws globalaccelerator list-endpoint-groups \
        "${ga_opts[@]}" \
        --listener-arn "${listener_arn}" \
        --query 'EndpointGroups[0].EndpointGroupArn' \
        --output text 2>/dev/null || echo ""
    )

    if [[ -n "${endpoint_group_arn}" && "${endpoint_group_arn}" != "None" ]]; then
      aws globalaccelerator delete-endpoint-group \
        "${ga_opts[@]}" \
        --endpoint-group-arn "${endpoint_group_arn}"
    fi

    aws globalaccelerator delete-listener \
      "${ga_opts[@]}" \
      --listener-arn "${listener_arn}"
  fi

  aws globalaccelerator update-accelerator \
    "${ga_opts[@]}" \
    --accelerator-arn "${global_accelerator_arn}" \
    --no-enabled

  echo "Aguardando Global Accelerator ser desabilitado (pode levar alguns minutos)..."
  for i in $(seq 1 40); do
    ga_status=$(
      aws globalaccelerator describe-accelerator \
        "${ga_opts[@]}" \
        --accelerator-arn "${global_accelerator_arn}" \
        --query 'Accelerator.Status' \
        --output text
    )
    echo "  Status: ${ga_status} (${i}/40)"
    if [[ "${ga_status}" == "DEPLOYED" ]]; then
      break
    fi
    sleep 15
  done

  aws globalaccelerator delete-accelerator \
    "${ga_opts[@]}" \
    --accelerator-arn "${global_accelerator_arn}"

  echo "Global Accelerator removido."
fi

# =============================================================================
# 7. WAF
# =============================================================================
echo "Removendo WAF..."
alb_arn=$(
  aws resourcegroupstaggingapi get-resources \
    --region "${aws_region?}" \
    --resource-type-filters elasticloadbalancing:loadbalancer \
    --tag-filters "Key=project,Values=${tag_project}" "Key=env,Values=${tag_env}" \
    --query 'ResourceTagMappingList[0].ResourceARN' \
    --output text
)

if [[ -n "${alb_arn}" && "${alb_arn}" != "None" ]]; then
  aws wafv2 disassociate-web-acl \
    --region "${aws_region?}" \
    --resource-arn "${alb_arn}"
fi

web_acl_id=$(
  aws wafv2 list-web-acls \
    --region "${aws_region?}" \
    --scope REGIONAL \
    --query "WebACLs[?Name=='${cluster_name}-web-acl'].Id" \
    --output text
)

if [[ -n "${web_acl_id}" && "${web_acl_id}" != "None" ]]; then
  lock_token=$(
    aws wafv2 get-web-acl \
      --region "${aws_region?}" \
      --scope REGIONAL \
      --name "${cluster_name}-web-acl" \
      --id "${web_acl_id}" \
      --query 'LockToken' --output text
  )

  aws wafv2 delete-web-acl \
    --region "${aws_region?}" \
    --scope REGIONAL \
    --name "${cluster_name}-web-acl" \
    --id "${web_acl_id}" \
    --lock-token "${lock_token}"
fi

# =============================================================================
# 8. Ingress + IngressClass
# =============================================================================
echo "Removendo Ingress e IngressClass..."
kubectl --namespace istio-ingress delete ingress alb-ingress --ignore-not-found
kubectl delete ingressclass alb --ignore-not-found

# =============================================================================
# 10. Istio
# =============================================================================
echo "Removendo Istio..."
helm uninstall istio-ingressgateway --namespace istio-ingress 2>/dev/null || true
helm uninstall istiod --namespace istio-system 2>/dev/null || true
helm uninstall istio-base --namespace istio-system 2>/dev/null || true

# CRDs do Istio são retidos pela resource policy — deletar explicitamente
kubectl get crd -o name | grep '\.istio\.io' | xargs -r kubectl delete

kubectl delete namespace istio-ingress --ignore-not-found
kubectl delete namespace istio-system --ignore-not-found

# =============================================================================
# 11. ALB Controller
# =============================================================================
echo "Removendo ALB Controller..."
helm uninstall aws-load-balancer-controller --namespace kube-system 2>/dev/null || true

eksctl delete iamserviceaccount \
  --cluster "${cluster_name?}" \
  --region "${aws_region?}" \
  --namespace kube-system \
  --name aws-load-balancer-controller

policy_arn=$(
  aws iam list-policies \
    --query "Policies[?PolicyName=='AWSLoadBalancerControllerIAMPolicy'].Arn" \
    --output text
)

if [[ -n "${policy_arn}" && "${policy_arn}" != "None" ]]; then
  aws iam delete-policy --policy-arn "${policy_arn}"
fi

# =============================================================================
# 12. Cluster EKS
# =============================================================================
echo "Removendo cluster EKS (aguarde vários minutos)..."
eksctl delete cluster \
  --name "${cluster_name?}" \
  --region "${aws_region?}" \
  --wait

# =============================================================================
# 13. VPC
# =============================================================================
echo "Removendo recursos de rede..."

# Route table associations (desassociar antes de deletar as route tables)
for rt in "${rt_public}" "${rt_private}"; do
  assoc_ids=$(
    aws ec2 describe-route-tables \
      --route-table-ids "${rt}" \
      --region "${aws_region?}" \
      --query 'RouteTables[0].Associations[?!Main].RouteTableAssociationId' \
      --output text
  )
  for assoc_id in ${assoc_ids}; do
    aws ec2 disassociate-route-table --association-id "${assoc_id}"
  done
done

# Routes customizadas
aws ec2 delete-route \
  --route-table-id "${rt_public?}" \
  --destination-cidr-block 0.0.0.0/0 2>/dev/null || true

aws ec2 delete-route \
  --route-table-id "${rt_private?}" \
  --destination-cidr-block 0.0.0.0/0 2>/dev/null || true

# Route tables
aws ec2 delete-route-table --route-table-id "${rt_public?}" --region "${aws_region?}"
aws ec2 delete-route-table --route-table-id "${rt_private?}" --region "${aws_region?}"

# NAT Gateway (demora alguns minutos)
echo "Removendo NAT Gateway (aguarde ~2 minutos)..."
aws ec2 delete-nat-gateway \
  --nat-gateway-id "${nat_gw_id?}" \
  --region "${aws_region?}"

aws ec2 wait nat-gateway-deleted \
  --nat-gateway-ids "${nat_gw_id?}" \
  --region "${aws_region?}"

# EIP
aws ec2 release-address \
  --allocation-id "${eip_alloc?}" \
  --region "${aws_region?}"

# Internet Gateway
aws ec2 detach-internet-gateway \
  --internet-gateway-id "${igw_id?}" \
  --vpc-id "${vpc_id?}"

aws ec2 delete-internet-gateway \
  --internet-gateway-id "${igw_id?}" \
  --region "${aws_region?}"

# Subnets
for subnet in "${subnet_pub_1a}" "${subnet_pub_1b}" "${subnet_priv_1a}" "${subnet_priv_1b}"; do
  aws ec2 delete-subnet --subnet-id "${subnet}" --region "${aws_region?}"
done

# VPC
aws ec2 delete-vpc --vpc-id "${vpc_id?}" --region "${aws_region?}"

echo ""
echo "Todos os recursos do lab foram removidos."
echo "Atenção: o certificado ACM não foi removido — deletar manualmente se necessário."

# Limpa arquivo de IDs para evitar uso acidental em execuções futuras
rm -f "$(dirname "$0")/.vpc-ids"
