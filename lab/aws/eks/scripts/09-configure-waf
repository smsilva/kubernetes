#!/bin/bash
# Passo 08: Cria WebACL no AWS WAF e associa ao ALB
# Shield Standard já está ativo por padrão em todos os recursos AWS — nenhuma configuração necessária

set -euo pipefail
. "$(dirname "$0")/env.conf"

# =============================================================================
# Obtém o ARN do ALB criado pelo Gateway no passo 06
# =============================================================================
alb_arn=$(
  aws resourcegroupstaggingapi get-resources \
    --region "${aws_region?}" \
    --resource-type-filters elasticloadbalancing:loadbalancer \
    --tag-filters "Key=project,Values=${tag_project}" "Key=env,Values=${tag_env}" \
    --query 'ResourceTagMappingList[0].ResourceARN' \
    --output text
)

if [[ -z "${alb_arn}" || "${alb_arn}" == "None" ]]; then
  echo "Erro: ALB não encontrado. Execute o passo 06 antes de continuar."
  exit 1
fi

echo "ALB ARN: ${alb_arn}"

# =============================================================================
# WebACL com AWS Managed Rules
# =============================================================================
echo "Criando WebACL..."
web_acl_arn=$(
  aws wafv2 list-web-acls \
    --region "${aws_region?}" \
    --scope REGIONAL \
    --query "WebACLs[?Name=='${cluster_name}-web-acl'].ARN" \
    --output text 2>/dev/null
)

if [[ -z "${web_acl_arn}" ]]; then
web_acl_arn=$(
  aws wafv2 create-web-acl \
    --region "${aws_region?}" \
    --name "${cluster_name}-web-acl" \
    --scope REGIONAL \
    --default-action Allow={} \
    --visibility-config "SampledRequestsEnabled=true,CloudWatchMetricsEnabled=true,MetricName=${cluster_name}-web-acl" \
    --rules '[
      {
        "Name": "AWSManagedRulesCommonRuleSet",
        "Priority": 1,
        "OverrideAction": {"None": {}},
        "Statement": {
          "ManagedRuleGroupStatement": {
            "VendorName": "AWS",
            "Name": "AWSManagedRulesCommonRuleSet"
          }
        },
        "VisibilityConfig": {
          "SampledRequestsEnabled": true,
          "CloudWatchMetricsEnabled": true,
          "MetricName": "AWSManagedRulesCommonRuleSet"
        }
      },
      {
        "Name": "AWSManagedRulesKnownBadInputsRuleSet",
        "Priority": 2,
        "OverrideAction": {"None": {}},
        "Statement": {
          "ManagedRuleGroupStatement": {
            "VendorName": "AWS",
            "Name": "AWSManagedRulesKnownBadInputsRuleSet"
          }
        },
        "VisibilityConfig": {
          "SampledRequestsEnabled": true,
          "CloudWatchMetricsEnabled": true,
          "MetricName": "AWSManagedRulesKnownBadInputsRuleSet"
        }
      },
      {
        "Name": "AWSManagedRulesAmazonIpReputationList",
        "Priority": 3,
        "OverrideAction": {"None": {}},
        "Statement": {
          "ManagedRuleGroupStatement": {
            "VendorName": "AWS",
            "Name": "AWSManagedRulesAmazonIpReputationList"
          }
        },
        "VisibilityConfig": {
          "SampledRequestsEnabled": true,
          "CloudWatchMetricsEnabled": true,
          "MetricName": "AWSManagedRulesAmazonIpReputationList"
        }
      }
    ]' \
    --query 'Summary.ARN' --output text
)
fi

echo "WebACL ARN: ${web_acl_arn}"

# =============================================================================
# Associa a WebACL ao ALB (com retry para WAFUnavailableEntityException)
# =============================================================================
echo "Associando WebACL ao ALB..."
for i in $(seq 1 10); do
  if aws wafv2 associate-web-acl \
    --region "${aws_region?}" \
    --web-acl-arn "${web_acl_arn?}" \
    --resource-arn "${alb_arn?}" 2>/dev/null; then
    break
  fi
  echo "  ALB ainda não indexado pelo WAF, aguardando 15s (tentativa ${i}/10)..."
  sleep 15
done

echo ""
echo "WAF configurado com sucesso."
echo "Regras ativas:"
echo "  - AWSManagedRulesCommonRuleSet       (proteção geral: XSS, SQLi, etc.)"
echo "  - AWSManagedRulesKnownBadInputsRuleSet (inputs maliciosos conhecidos)"
echo "  - AWSManagedRulesAmazonIpReputationList (IPs maliciosos e botnets)"
echo ""
echo "Shield Standard: ativo por padrão em todos os recursos AWS (sem custo adicional)"

# =============================================================================
# Verificação
# =============================================================================
echo ""
echo "--- Verificação ---"

echo "WebACL associada ao ALB:"
aws wafv2 get-web-acl-for-resource \
  --region "${aws_region?}" \
  --resource-arn "${alb_arn?}" \
  --query 'WebACL.{Nome:Name,ARN:ARN}' \
  --output table

echo ""
echo "Regras da WebACL:"
# ARN do WAFv2: arn:aws:wafv2:<region>:<account>:regional/webacl/<name>/<uuid>
# --id exige o UUID (último segmento), não o name
web_acl_id="$(echo "${web_acl_arn?}" | awk -F'/' '{print $NF}')"
aws wafv2 get-web-acl \
  --region "${aws_region?}" \
  --scope REGIONAL \
  --id "${web_acl_id}" \
  --name "${cluster_name}-web-acl" \
  --query 'WebACL.Rules[*].{Nome:Name,Prioridade:Priority}' \
  --output table
