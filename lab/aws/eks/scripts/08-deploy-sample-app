#!/bin/bash
# Passo 07: Deploy de app de exemplo para validar o fluxo ALB → Istio → app

set -euo pipefail
. "$(dirname "$0")/env.conf"

kubectl apply -f - <<EOF
---
apiVersion: v1
kind: Namespace
metadata:
  name: sample
  labels:
    istio-injection: enabled
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: httpbin
  namespace: sample
spec:
  replicas: 1
  selector:
    matchLabels:
      app: httpbin
  template:
    metadata:
      labels:
        app: httpbin
    spec:
      containers:
        - name: httpbin
          image: kennethreitz/httpbin
          ports:
            - containerPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: httpbin
  namespace: sample
spec:
  selector:
    app: httpbin
  ports:
    - port: 8000
      targetPort: 80
---
apiVersion: networking.istio.io/v1
kind: Gateway
metadata:
  name: httpbin-gateway
  namespace: sample
spec:
  selector:
    app: istio-ingressgateway
  servers:
    - port:
        number: 80
        name: http
        protocol: HTTP
      hosts:
        - "httpbin.${domain}"
---
apiVersion: networking.istio.io/v1
kind: VirtualService
metadata:
  name: httpbin
  namespace: sample
spec:
  hosts:
    - "httpbin.${domain}"
  gateways:
    - httpbin-gateway
  http:
    - route:
        - destination:
            host: httpbin
            port:
              number: 8000
EOF

kubectl --namespace sample wait deployment/httpbin \
  --for condition=Available \
  --timeout=120s

echo ""
echo "App disponível em: https://httpbin.${domain}/get"

# =============================================================================
# Verificação
# =============================================================================
echo ""
echo "--- Verificação ---"

kubectl -n sample get deployment,svc,gateway,virtualservice

echo ""
echo "Pods:"
kubectl -n sample get pods -o wide

echo ""
echo "Testando endpoint (fluxo completo: ALB → Istio → httpbin):"
curl -s "https://httpbin.${domain}/get" | python3 -m json.tool
