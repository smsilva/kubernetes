#!/bin/bash
# Passo 07: Cria o ALB via Ingress apontando para o Istio IngressGateway (TLS via ACM)

set -euo pipefail
. "$(dirname "$0")/env.conf"
. "$(dirname "$0")/.vpc-ids"

if [[ -z "${cert_arn}" ]]; then
  echo "Erro: cert_arn não definido em env.conf"
  echo "Importe ou solicite o certificado no ACM e preencha a variável cert_arn"
  exit 1
fi

# O certificado ACM é wildcard (*.wasp.silvios.me), então cobre todos os subdomínios
# automaticamente. Não é necessário criar entradas DNS individuais por subdomínio —
# basta um registro CNAME *.wasp.silvios.me → ALB hostname no Azure DNS.
# Exceção: idp.wasp.silvios.me aponta para o CloudFront do Cognito (script 12).

# =============================================================================
# IngressClass + Ingress
# =============================================================================
kubectl apply -f - <<EOF
---
apiVersion: networking.k8s.io/v1
kind: IngressClass
metadata:
  name: alb
spec:
  controller: ingress.k8s.aws/alb
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: alb-ingress
  namespace: istio-ingress
  annotations:
    kubernetes.io/ingress.class: alb
    alb.ingress.kubernetes.io/scheme: internet-facing
    alb.ingress.kubernetes.io/target-type: ip
    alb.ingress.kubernetes.io/certificate-arn: ${cert_arn}
    alb.ingress.kubernetes.io/ssl-redirect: "443"
    alb.ingress.kubernetes.io/listen-ports: '[{"HTTP":80},{"HTTPS":443}]'
    alb.ingress.kubernetes.io/subnets: ${subnet_pub_1a},${subnet_pub_1b}
    alb.ingress.kubernetes.io/tags: project=${tag_project},env=${tag_env}
    alb.ingress.kubernetes.io/healthcheck-port: "15021"
    alb.ingress.kubernetes.io/healthcheck-path: /healthz/ready
    alb.ingress.kubernetes.io/success-codes: "200"
spec:
  ingressClassName: alb
  rules:
    # Wildcard cobre todos os subdomínios exceto o apex
    - host: "*.${domain}"
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: istio-ingressgateway
                port:
                  number: 80
    # Apex deve ser declarado explicitamente — *.domain não cobre domain
    - host: "${domain}"
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: istio-ingressgateway
                port:
                  number: 80
EOF

echo ""
echo "Aguardando o ALB ficar disponível..."
kubectl --namespace istio-ingress wait ingress/alb-ingress \
  --for=jsonpath='{.status.loadBalancer.ingress[0].hostname}' \
  --timeout=180s 2>/dev/null \
  || true

alb_hostname=$(
  kubectl --namespace istio-ingress get ingress alb-ingress \
    --output jsonpath='{.status.loadBalancer.ingress[0].hostname}'
)

echo ""
echo "ALB hostname: ${alb_hostname}"

# =============================================================================
# Registro DNS no Azure (${domain} está na Azure DNS)
# =============================================================================
az_zone="${domain}"

echo "Criando registro CNAME *.${domain} → ${alb_hostname} no Azure DNS..."

az network dns record-set cname set-record \
  --subscription "${az_subscription}" \
  --resource-group "${az_resource_group}" \
  --zone-name "${az_zone}" \
  --record-set-name "*" \
  --ttl 300 \
  --cname "${alb_hostname}"

# =============================================================================
# Verificação
# =============================================================================
echo ""
echo "--- Verificação ---"

kubectl -n istio-ingress get ingress alb-ingress -o wide

echo ""
alb_name=$(echo "${alb_hostname}" | cut -d. -f1 | rev | cut -d- -f2- | rev)
aws elbv2 describe-load-balancers \
  --region "${aws_region?}" \
  --query "LoadBalancers[?contains(DNSName,'${alb_hostname}')].{Nome:LoadBalancerName,DNS:DNSName,Estado:State.Code,Scheme:Scheme}" \
  --output table

echo ""
echo "Listeners:"
alb_arn=$(aws elbv2 describe-load-balancers \
  --region "${aws_region?}" \
  --query "LoadBalancers[?DNSName=='${alb_hostname}'].LoadBalancerArn" \
  --output text)
aws elbv2 describe-listeners \
  --load-balancer-arn "${alb_arn}" \
  --region "${aws_region?}" \
  --query 'Listeners[*].{Porta:Port,Protocolo:Protocol,AcaoDefault:DefaultActions[0].Type}' \
  --output table

echo ""
echo "Registro DNS wildcard:"
az network dns record-set cname show \
  --subscription "${az_subscription}" \
  --resource-group "${az_resource_group}" \
  --zone-name "${az_zone}" \
  --name "*" \
  --query '{Nome:fqdn,CNAME:CNAMERecord.cname}' \
  --output table

echo ""
echo "Nota: o apex ${domain} ainda não tem registro — será configurado no passo 07b (Global Accelerator)."
echo "Próximo passo: scripts/07b-configure-global-accelerator"
