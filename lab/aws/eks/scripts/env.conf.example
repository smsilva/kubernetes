aws_region="us-east-1"
instance_name="wasp"
cluster_name="wasp-calm-crow-ndx4"
cluster_version="1.34"

# VPC
vpc_cidr="10.0.0.0/16"
subnet_public_1a_cidr="10.0.1.0/24"
subnet_public_1b_cidr="10.0.2.0/24"
subnet_private_1a_cidr="10.0.3.0/24"
subnet_private_1b_cidr="10.0.4.0/24"

# Nodes
node_type="t3.medium"
node_min=2
node_max=5
node_desired=2

# Azure DNS
az_subscription="wasp-sandbox"
az_resource_group="wasp-foundation"

# Domínio e certificado (ACM)
domain="wasp.silvios.me"
cert_arn=""

# Tags
tag_project="eks-lab"
tag_env="lab"

# Global Accelerator — preenchido automaticamente pelo passo 07b
global_accelerator_arn=""

# Cognito — preenchido automaticamente pelos scripts 11 e 12
cognito_user_pool_id=""
cognito_app_client_id=""
cognito_cloudfront_domain=""
