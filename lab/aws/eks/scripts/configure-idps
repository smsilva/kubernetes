#!/bin/bash
this_script_path="$(realpath ${0})"
this_script_name="${this_script_path##*/}"
this_script_directory="${this_script_path%/*}"

PATH="${this_script_directory}:${PATH}"

. "${this_script_directory}/env.conf"

secrets_file="${this_script_directory}/env.secrets"
if [[ -f "${secrets_file}" ]]; then
  # shellcheck source=/dev/null
  . "${secrets_file}"
fi

dynamodb_table="tenant-registry"
user_pool_name="wasp-platform"

show_usage() {
  cat <<EOF

  Registra um IdP (Google ou Microsoft) + App Client + DynamoDB para um tenant.
  Pré-requisito: scripts/11-create-cognito já executado (User Pool deve existir).

    Options:

      -h,   --help                Show this help
      -t,   --tenant              Nome do tenant (ex: customer2)
      -p,   --provider            Provedor de identidade: google | microsoft
      -d,   --domain              Domínio de email do tenant (ex: msn.com)
      -ci,  --client-id           Client ID do IdP (não sensível)
            --client-secret-stdin Lê o client secret do stdin

    Examples:

      echo "\${GOOGLE_CLIENT_SECRET}" | ${this_script_name} \\
        --tenant customer3 \\
        --provider google \\
        --domain gmail.com \\
        --client-id "\${GOOGLE_CLIENT_ID}" \\
        --client-secret-stdin

      echo "\${AZURE_CLIENT_SECRET}" | ${this_script_name} \\
        --tenant customer2 \\
        --provider microsoft \\
        --domain msn.com \\
        --client-id "\${AZURE_CLIENT_ID}" \\
        --client-secret-stdin

EOF
}

while [[ "${1}" =~ ^- && ! "${1}" == "--" ]]; do
  case $1 in
    -h | --help )
      show_usage
      exit 0
      ;;

    -t | --tenant )
      shift
      tenant="${1}"
      ;;

    -p | --provider )
      shift
      provider="${1}"
      ;;

    -d | --domain )
      shift
      tenant_domain="${1}"
      ;;

    -ci | --client-id )
      shift
      client_id="${1}"
      ;;

    --client-secret-stdin )
      read_stdin=true
      ;;

    * )
      echo "Invalid option: ${1}"
      show_usage
      exit 1
      ;;

  esac
  shift
done

if [[ "${1}" == '--' ]]; then shift; fi

# =============================================================================
# Validação
# =============================================================================
missing=false
for arg in tenant provider tenant_domain client_id; do
  if [[ -z "${!arg:-}" ]]; then
    echo "Erro: --${arg//_/-} é obrigatório"
    missing=true
  fi
done

if [[ "${read_stdin:-false}" != true ]]; then
  echo "Erro: --client-secret-stdin é obrigatório"
  echo "  Uso: echo \"\${CLIENT_SECRET}\" | ${this_script_name} --client-secret-stdin ..."
  missing=true
fi

if [[ "${missing}" == true ]]; then
  show_usage
  exit 1
fi

client_secret=$(cat)

if [[ -z "${client_secret}" ]]; then
  echo "Erro: nenhum client secret recebido via stdin"
  exit 1
fi

# =============================================================================
# Derivar valores do provider
# =============================================================================
tenant_upper="${tenant^^}"
tenant_url="${tenant}.${domain}"

case "${provider}" in
  google)
    idp_name="Google-${tenant^}"
    provider_type="Google"
    provider_details="client_id=${client_id},client_secret=${client_secret},authorize_scopes=openid email profile"
    ;;
  microsoft)
    idp_name="MicrosoftAD-${tenant^}"
    provider_type="OIDC"
    # GUID fixo para contas pessoais Microsoft (MSN/Hotmail/Outlook) — consumers tenant
    microsoft_oidc_issuer="https://login.microsoftonline.com/9188040d-6c67-4c5b-b112-36a304b66dad/v2.0"
    provider_details="client_id=${client_id},client_secret=${client_secret},authorize_scopes=openid email profile,oidc_issuer=${microsoft_oidc_issuer},attributes_request_method=GET"
    ;;
  *)
    echo "Erro: --provider deve ser 'google' ou 'microsoft' (recebido: '${provider}')"
    exit 1
    ;;
esac

# =============================================================================
# Localiza User Pool
# =============================================================================
echo "Localizando User Pool '${user_pool_name}'..."

pool_id=$(
  aws cognito-idp list-user-pools \
    --region "${aws_region}" \
    --max-results 60 \
    --query "UserPools[?Name=='${user_pool_name}'].Id" \
    --output text
)

if [[ -z "${pool_id}" ]]; then
  echo "Erro: User Pool '${user_pool_name}' não encontrado — execute scripts/11-create-cognito primeiro"
  exit 1
fi

echo "User Pool: ${pool_id}"

# =============================================================================
# IdP
# =============================================================================
echo "Verificando IdP '${idp_name}'..."

idp_exists=$(
  aws cognito-idp describe-identity-provider \
    --region "${aws_region}" \
    --user-pool-id "${pool_id}" \
    --provider-name "${idp_name}" \
    --query 'IdentityProvider.ProviderName' \
    --output text 2>/dev/null || echo ""
)

if [[ -z "${idp_exists}" ]]; then
  echo "Criando IdP '${idp_name}'..."
  aws cognito-idp create-identity-provider \
    --region "${aws_region}" \
    --user-pool-id "${pool_id}" \
    --provider-name "${idp_name}" \
    --provider-type "${provider_type}" \
    --provider-details "${provider_details}" \
    --attribute-mapping "email=email,name=name" \
    > /dev/null
  echo "IdP criado: ${idp_name}"
else
  echo "IdP já existe: ${idp_name}"
fi

# =============================================================================
# App Client
# =============================================================================
echo "Verificando App Client '${tenant}'..."

app_client_id=$(
  aws cognito-idp list-user-pool-clients \
    --region "${aws_region}" \
    --user-pool-id "${pool_id}" \
    --query "UserPoolClients[?ClientName=='${tenant}'].ClientId" \
    --output text
)

if [[ -z "${app_client_id}" ]]; then
  echo "Criando App Client '${tenant}'..."
  app_client_id=$(
    aws cognito-idp create-user-pool-client \
      --region "${aws_region}" \
      --user-pool-id "${pool_id}" \
      --client-name "${tenant}" \
      --generate-secret \
      --supported-identity-providers "${idp_name}" \
      --allowed-o-auth-flows code \
      --allowed-o-auth-scopes openid email profile \
      --allowed-o-auth-flows-user-pool-client \
      --callback-urls "https://auth.${domain}/callback" \
      --logout-urls "https://${tenant_url}/logout" \
      --query 'UserPoolClient.ClientId' \
      --output text
  )
  echo "App Client criado: ${app_client_id}"
else
  echo "App Client já existe: ${app_client_id}"
fi

# =============================================================================
# Client secret → env.secrets
# =============================================================================
app_client_secret=$(
  aws cognito-idp describe-user-pool-client \
    --region "${aws_region}" \
    --user-pool-id "${pool_id}" \
    --client-id "${app_client_id}" \
    --query 'UserPoolClient.ClientSecret' \
    --output text
)

secret_key="IDP_CLIENT_SECRET_${tenant_upper}"

if grep -q "^${secret_key}=" "${secrets_file}" 2>/dev/null; then
  sed -i "s|^${secret_key}=.*|${secret_key}=\"${app_client_secret}\"|" "${secrets_file}"
else
  echo "${secret_key}=\"${app_client_secret}\"" >> "${secrets_file}"
fi
echo "${secret_key} salvo em env.secrets (${app_client_secret:0:4}...)"

# =============================================================================
# DynamoDB
# =============================================================================
echo "Registrando tenant '${tenant}' no DynamoDB (domain: ${tenant_domain})..."

item=$(cat <<EOF
{
  "pk":                    {"S": "domain#${tenant_domain}"},
  "tenant_id":             {"S": "${tenant}"},
  "url":                   {"S": "${tenant_url}"},
  "regions":               {"L": [{"S": "${aws_region}"}]},
  "cognito_app_client_id": {"S": "${app_client_id}"},
  "auth": {"M": {
    "type":                  {"S": "${provider}"},
    "cognito_user_pool_id":  {"S": "${pool_id}"},
    "cognito_app_client_id": {"S": "${app_client_id}"},
    "cognito_idp_name":      {"S": "${idp_name}"}
  }},
  "status": {"S": "active"}
}
EOF
)

aws dynamodb put-item \
  --region "${aws_region}" \
  --table-name "${dynamodb_table}" \
  --item "${item}"

echo "Tenant registrado."

# =============================================================================
# Verificação
# =============================================================================
echo ""
echo "--- Verificação ---"

echo "IdP:"
aws cognito-idp describe-identity-provider \
  --region "${aws_region}" \
  --user-pool-id "${pool_id}" \
  --provider-name "${idp_name}" \
  --query 'IdentityProvider.{Nome:ProviderName,Tipo:ProviderType}' \
  --output table

echo ""
echo "App Client:"
aws cognito-idp describe-user-pool-client \
  --region "${aws_region}" \
  --user-pool-id "${pool_id}" \
  --client-id "${app_client_id}" \
  --query 'UserPoolClient.{ClientId:ClientId,Nome:ClientName,Callbacks:CallbackURLs,IdPs:SupportedIdentityProviders}' \
  --output table

echo ""
echo "DynamoDB:"
aws dynamodb get-item \
  --region "${aws_region}" \
  --table-name "${dynamodb_table}" \
  --key "{\"pk\": {\"S\": \"domain#${tenant_domain}\"}}" \
  --output table

echo ""
echo "Teste discovery:"
echo "  curl \"https://discovery.${domain}/tenant?domain=${tenant_domain}\""
