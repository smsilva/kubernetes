#!/bin/bash
# Passo 13: Build, push para Docker Hub e deploy dos três serviços + namespaces customer1 + tenant-frontend

set -euo pipefail
. "$(dirname "$0")/env.conf"

scripts_dir="$(cd "$(dirname "$0")" && pwd)"
secrets_file="${scripts_dir}/env.secrets"

# Carrega env.secrets se existir (fonte de COGNITO_CLIENT_SECRET e STATE_JWT_SECRET)
if [[ -f "${secrets_file}" ]]; then
  # shellcheck source=/dev/null
  . "${secrets_file}"
fi
services_dir="${scripts_dir}/../services"
aws_account_id=$(aws sts get-caller-identity --query Account --output text)

image_tag="$(git -C "${services_dir}" rev-parse --short HEAD)"
container_image_discovery="silviosilva/wasp-discovery:${image_tag}"
container_image_platform_frontend="silviosilva/wasp-platform-frontend:${image_tag}"
container_image_callback_handler="silviosilva/wasp-callback-handler:${image_tag}"
container_image_tenant_frontend="silviosilva/wasp-tenant-frontend:${image_tag}"

# =============================================================================
# Validação
# =============================================================================
for var in cognito_user_pool_id cognito_app_client_id; do
  if [[ -z "${!var:-}" ]]; then
    echo "Erro: ${var} não definido em env.conf — execute os passos 11 e 12 primeiro"
    exit 1
  fi
done

if [[ -z "${COGNITO_CLIENT_SECRET_CUSTOMER1:-}" ]]; then
  echo "Erro: variável de ambiente COGNITO_CLIENT_SECRET_CUSTOMER1 não definida"
  echo "  Recupere com:"
  echo "  aws cognito-idp describe-user-pool-client \\"
  echo "    --region ${aws_region} \\"
  echo "    --user-pool-id ${cognito_user_pool_id} \\"
  echo "    --client-id ${cognito_app_client_id} \\"
  echo "    --query UserPoolClient.ClientSecret --output text"
  exit 1
fi

if [[ -z "${STATE_JWT_SECRET:-}" ]]; then
  echo "STATE_JWT_SECRET não definido — gerando e salvando em env.secrets..."
  STATE_JWT_SECRET="$(openssl rand -hex 32)"
  sed -i "s|^STATE_JWT_SECRET=.*|STATE_JWT_SECRET=\"${STATE_JWT_SECRET}\"|" "${secrets_file}"
  echo "STATE_JWT_SECRET salvo em env.secrets"
fi

# =============================================================================
# Build e push das imagens para Docker Hub
# =============================================================================
declare -A service_images=(
  [discovery]="${container_image_discovery}"
  [platform-frontend]="${container_image_platform_frontend}"
  [callback-handler]="${container_image_callback_handler}"
  [tenant-frontend]="${container_image_tenant_frontend}"
)

for svc in discovery platform-frontend callback-handler tenant-frontend; do
  echo "Build: ${svc}..."
  docker build \
    --platform linux/amd64 \
    -t "${service_images[${svc}]}" \
    "${services_dir}/${svc}"

  echo "Push: ${service_images[${svc}]}..."
  docker push "${service_images[${svc}]}"
done

# =============================================================================
# IRSA — discovery precisa ler o DynamoDB
# =============================================================================
dynamodb_table="tenant-registry"
irsa_role_name="wasp-discovery-irsa"

echo "Configurando IRSA para o serviço discovery..."

oidc_issuer=$(
  aws eks describe-cluster \
    --region "${aws_region}" \
    --name "${cluster_name}" \
    --query 'cluster.identity.oidc.issuer' \
    --output text
)
oidc_provider="${oidc_issuer#https://}"
oidc_provider_arn="arn:aws:iam::${aws_account_id}:oidc-provider/${oidc_provider}"

if ! aws iam get-role --role-name "${irsa_role_name}" > /dev/null 2>&1; then
  echo "Criando IAM role '${irsa_role_name}'..."
  aws iam create-role \
    --role-name "${irsa_role_name}" \
    --assume-role-policy-document "{
      \"Version\": \"2012-10-17\",
      \"Statement\": [{
        \"Effect\": \"Allow\",
        \"Principal\": {\"Federated\": \"${oidc_provider_arn}\"},
        \"Action\": \"sts:AssumeRoleWithWebIdentity\",
        \"Condition\": {
          \"StringEquals\": {
            \"${oidc_provider}:sub\": \"system:serviceaccount:discovery:discovery\",
            \"${oidc_provider}:aud\": \"sts.amazonaws.com\"
          }
        }
      }]
    }" > /dev/null

  aws iam put-role-policy \
    --role-name "${irsa_role_name}" \
    --policy-name "DynamoDBTenantRegistryRead" \
    --policy-document "{
      \"Version\": \"2012-10-17\",
      \"Statement\": [{
        \"Effect\": \"Allow\",
        \"Action\": [\"dynamodb:GetItem\", \"dynamodb:Query\"],
        \"Resource\": [
          \"arn:aws:dynamodb:${aws_region}:${aws_account_id}:table/${dynamodb_table}\",
          \"arn:aws:dynamodb:${aws_region}:${aws_account_id}:table/${dynamodb_table}/index/*\"
        ]
      }]
    }"
  echo "IAM role criada: ${irsa_role_name}"
else
  echo "IAM role já existe: ${irsa_role_name}"
fi

irsa_role_arn="arn:aws:iam::${aws_account_id}:role/${irsa_role_name}"

# =============================================================================
# Deploy: discovery
# =============================================================================
echo "Deploying: discovery..."

kubectl apply -f - <<EOF
---
apiVersion: v1
kind: Namespace
metadata:
  name: discovery
  labels:
    istio-injection: enabled
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: discovery-config
  namespace: discovery
data:
  DYNAMODB_TABLE: "${dynamodb_table}"
  AWS_REGION: "${aws_region}"
  LOG_LEVEL: "INFO"
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: discovery
  namespace: discovery
  annotations:
    eks.amazonaws.com/role-arn: "${irsa_role_arn}"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: discovery
  namespace: discovery
spec:
  replicas: 1
  selector:
    matchLabels:
      app: discovery
  template:
    metadata:
      labels:
        app: discovery
    spec:
      serviceAccountName: discovery
      containers:
        - name: discovery
          image: ${container_image_discovery}
          ports:
            - containerPort: 8000
          envFrom:
            - configMapRef:
                name: discovery-config
          readinessProbe:
            httpGet:
              path: /health
              port: 8000
            initialDelaySeconds: 5
            periodSeconds: 10
---
apiVersion: v1
kind: Service
metadata:
  name: discovery
  namespace: discovery
spec:
  selector:
    app: discovery
  ports:
    - port: 8000
      targetPort: 8000
---
apiVersion: networking.istio.io/v1
kind: Gateway
metadata:
  name: discovery-gateway
  namespace: discovery
spec:
  selector:
    app: istio-ingressgateway
  servers:
    - port:
        number: 80
        name: http
        protocol: HTTP
      hosts:
        - "discovery.${domain}"
---
apiVersion: networking.istio.io/v1
kind: VirtualService
metadata:
  name: discovery
  namespace: discovery
spec:
  hosts:
    - "discovery.${domain}"
  gateways:
    - discovery-gateway
  http:
    - route:
        - destination:
            host: discovery
            port:
              number: 8000
EOF

# =============================================================================
# Deploy: platform-frontend
# =============================================================================
echo "Deploying: platform-frontend..."

kubectl apply -f - <<EOF
---
apiVersion: v1
kind: Namespace
metadata:
  name: platform
  labels:
    istio-injection: enabled
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: platform-frontend
  namespace: platform
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: platform-frontend-config
  namespace: platform
data:
  DISCOVERY_URL: "https://discovery.${domain}"
  COGNITO_DOMAIN: "idp.${domain}"
  COGNITO_CLIENT_ID: "${cognito_app_client_id}"
  CALLBACK_URL: "https://auth.${domain}/callback"
  LOG_LEVEL: "INFO"
---
apiVersion: v1
kind: Secret
metadata:
  name: platform-frontend-secret
  namespace: platform
type: Opaque
stringData:
  STATE_JWT_SECRET: "${STATE_JWT_SECRET}"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: platform-frontend
  namespace: platform
spec:
  replicas: 1
  selector:
    matchLabels:
      app: platform-frontend
  template:
    metadata:
      labels:
        app: platform-frontend
    spec:
      serviceAccountName: platform-frontend
      containers:
        - name: platform-frontend
          image: ${container_image_platform_frontend}
          ports:
            - containerPort: 8000
          envFrom:
            - configMapRef:
                name: platform-frontend-config
            - secretRef:
                name: platform-frontend-secret
          readinessProbe:
            httpGet:
              path: /health
              port: 8000
            initialDelaySeconds: 5
            periodSeconds: 10
---
apiVersion: v1
kind: Service
metadata:
  name: platform-frontend
  namespace: platform
spec:
  selector:
    app: platform-frontend
  ports:
    - port: 8000
      targetPort: 8000
---
apiVersion: networking.istio.io/v1
kind: Gateway
metadata:
  name: platform-gateway
  namespace: platform
spec:
  selector:
    app: istio-ingressgateway
  servers:
    - port:
        number: 80
        name: http
        protocol: HTTP
      hosts:
        - "${domain}"
---
apiVersion: networking.istio.io/v1
kind: VirtualService
metadata:
  name: platform-frontend
  namespace: platform
spec:
  hosts:
    - "${domain}"
  gateways:
    - platform-gateway
  http:
    - route:
        - destination:
            host: platform-frontend
            port:
              number: 8000
EOF

# =============================================================================
# Deploy: callback-handler
# =============================================================================
echo "Deploying: callback-handler..."

kubectl apply -f - <<EOF
---
apiVersion: v1
kind: Namespace
metadata:
  name: auth
  labels:
    istio-injection: enabled
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: callback-handler
  namespace: auth
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: callback-handler-config
  namespace: auth
data:
  DISCOVERY_URL: "https://discovery.${domain}"
  COGNITO_DOMAIN: "idp.${domain}"
  COGNITO_CLIENT_ID: "${cognito_app_client_id}"
  CALLBACK_URL: "https://auth.${domain}/callback"
  PLATFORM_URL: "https://${domain}"
  SESSION_COOKIE_DOMAIN: ".${domain}"
  LOG_LEVEL: "INFO"
---
apiVersion: v1
kind: Secret
metadata:
  name: callback-handler-secret
  namespace: auth
type: Opaque
stringData:
  COGNITO_CLIENT_SECRET_CUSTOMER1: "${COGNITO_CLIENT_SECRET_CUSTOMER1}"
  STATE_JWT_SECRET: "${STATE_JWT_SECRET}"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: callback-handler
  namespace: auth
spec:
  replicas: 1
  selector:
    matchLabels:
      app: callback-handler
  template:
    metadata:
      labels:
        app: callback-handler
    spec:
      serviceAccountName: callback-handler
      containers:
        - name: callback-handler
          image: ${container_image_callback_handler}
          ports:
            - containerPort: 8000
          envFrom:
            - configMapRef:
                name: callback-handler-config
            - secretRef:
                name: callback-handler-secret
          readinessProbe:
            httpGet:
              path: /health
              port: 8000
            initialDelaySeconds: 5
            periodSeconds: 10
---
apiVersion: v1
kind: Service
metadata:
  name: callback-handler
  namespace: auth
spec:
  selector:
    app: callback-handler
  ports:
    - port: 8000
      targetPort: 8000
---
apiVersion: networking.istio.io/v1
kind: Gateway
metadata:
  name: auth-gateway
  namespace: auth
spec:
  selector:
    app: istio-ingressgateway
  servers:
    - port:
        number: 80
        name: http
        protocol: HTTP
      hosts:
        - "auth.${domain}"
---
apiVersion: networking.istio.io/v1
kind: VirtualService
metadata:
  name: callback-handler
  namespace: auth
spec:
  hosts:
    - "auth.${domain}"
  gateways:
    - auth-gateway
  http:
    - route:
        - destination:
            host: callback-handler
            port:
              number: 8000
EOF

# =============================================================================
# Deploy: customer1 (tenant-frontend + httpbin como backend interno)
# =============================================================================
echo "Deploying: customer1..."

kubectl apply -f - <<EOF
---
apiVersion: v1
kind: Namespace
metadata:
  name: customer1
  labels:
    istio-injection: enabled
---
# httpbin: backend interno acessado apenas pelo tenant-frontend via HTTPBIN_URL
apiVersion: apps/v1
kind: Deployment
metadata:
  name: httpbin
  namespace: customer1
spec:
  replicas: 1
  selector:
    matchLabels:
      app: httpbin
  template:
    metadata:
      labels:
        app: httpbin
    spec:
      containers:
        - name: httpbin
          image: kennethreitz/httpbin
          ports:
            - containerPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: httpbin
  namespace: customer1
spec:
  selector:
    app: httpbin
  ports:
    - port: 8000
      targetPort: 80
---
# tenant-frontend: app principal exposta externamente
apiVersion: v1
kind: ConfigMap
metadata:
  name: tenant-frontend-config
  namespace: customer1
data:
  HTTPBIN_URL: "https://httpbin.${domain}"
  PLATFORM_URL: "https://${domain}"
  CUSTOMER1_URL: "https://customer1.${domain}"
  CUSTOMER2_URL: "https://customer2.${domain}"
  LOG_LEVEL: "INFO"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: tenant-frontend
  namespace: customer1
spec:
  replicas: 1
  selector:
    matchLabels:
      app: tenant-frontend
  template:
    metadata:
      labels:
        app: tenant-frontend
    spec:
      containers:
        - name: tenant-frontend
          image: ${container_image_tenant_frontend}
          ports:
            - containerPort: 8000
          envFrom:
            - configMapRef:
                name: tenant-frontend-config
---
apiVersion: v1
kind: Service
metadata:
  name: tenant-frontend
  namespace: customer1
spec:
  selector:
    app: tenant-frontend
  ports:
    - port: 8000
      targetPort: 8000
---
apiVersion: networking.istio.io/v1
kind: Gateway
metadata:
  name: customer1-gateway
  namespace: customer1
spec:
  selector:
    app: istio-ingressgateway
  servers:
    - port:
        number: 80
        name: http
        protocol: HTTP
      hosts:
        - "customer1.${domain}"
---
apiVersion: networking.istio.io/v1
kind: VirtualService
metadata:
  name: customer1
  namespace: customer1
spec:
  hosts:
    - "customer1.${domain}"
  gateways:
    - customer1-gateway
  http:
    - route:
        - destination:
            host: tenant-frontend
            port:
              number: 8000
EOF

# =============================================================================
# Aguarda os deployments ficarem prontos
# =============================================================================
echo "Aguardando deployments..."

for ns_deploy in discovery/discovery platform/platform-frontend auth/callback-handler customer1/httpbin customer1/tenant-frontend; do
  ns="${ns_deploy%%/*}"
  deploy="${ns_deploy##*/}"
  kubectl -n "${ns}" wait deployment/"${deploy}" \
    --for condition=Available \
    --timeout=180s
  echo "  ${ns}/${deploy}: pronto"
done

# =============================================================================
# Verificação
# =============================================================================
echo ""
echo "--- Verificação ---"

for ns in discovery platform auth customer1; do
  echo ""
  echo "Namespace: ${ns}"
  kubectl -n "${ns}" get deployment,svc,gateway,virtualservice 2>/dev/null
done

echo ""
echo "Pods:"
kubectl get pods -A -l 'app in (discovery,platform-frontend,callback-handler,httpbin,tenant-frontend)'

echo ""
echo "Endpoints disponíveis:"
echo "  https://${domain}                       → platform-frontend"
echo "  https://discovery.${domain}/health      → discovery"
echo "  https://auth.${domain}/health           → callback-handler"
echo "  https://customer1.${domain}             → tenant-frontend (requer JWT após passo 14)"
echo ""
echo "Próximo passo: scripts/14-configure-istio-auth"
echo "  Configura RequestAuthentication e AuthorizationPolicy no namespace customer1"
