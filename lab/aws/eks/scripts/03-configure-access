#!/bin/bash
# Passo 03: Configura o kubeconfig e acesso admin ao cluster para o caller IAM

set -euo pipefail
. "$(dirname "$0")/env.conf"

# Atualiza o kubeconfig local
aws eks update-kubeconfig \
  --region "${aws_region?}" \
  --name "${cluster_name?}"

# Obtém o ARN da role IAM do caller (assumed-role → IAM role ARN)
role_name=$(
  aws sts get-caller-identity \
    --query 'Arn' \
    --output text \
  | grep -oP '(?<=assumed-role/)[^/]+'
)

caller_arn=$(
  aws iam get-role \
    --role-name "${role_name?}" \
    --query 'Role.Arn' \
    --output text
)

echo "Caller ARN: ${caller_arn}"

# Cria o access entry para o caller
aws eks create-access-entry \
  --cluster-name "${cluster_name?}" \
  --region "${aws_region?}" \
  --principal-arn "${caller_arn?}"

# Associa a policy de admin ao cluster
aws eks associate-access-policy \
  --cluster-name "${cluster_name?}" \
  --region "${aws_region?}" \
  --principal-arn "${caller_arn?}" \
  --policy-arn arn:aws:eks::aws:cluster-access-policy/AmazonEKSClusterAdminPolicy \
  --access-scope type=cluster

echo ""
kubectl get nodes -o wide

# =============================================================================
# Verificação
# =============================================================================
echo ""
echo "--- Verificação ---"

aws eks list-access-entries --cluster-name "${cluster_name?}" --region "${aws_region?}" \
  --query 'accessEntries' --output table

echo ""
aws eks list-associated-access-policies \
  --cluster-name "${cluster_name?}" \
  --region "${aws_region?}" \
  --principal-arn "${caller_arn?}" \
  --query 'associatedAccessPolicies[*].{Policy:policyArn,Scope:accessScope.type}' \
  --output table
